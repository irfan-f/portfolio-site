{
  "name": "portfolio-site",
  "version": "1.0.0",
  "private": false,
  "homepage": "https://irfan-f.com",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:images": "node scripts/generate-images.mjs",
    "generate-images": "npm run build:images",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:desktop": "playwright test --project=desktop-chromium",
    "test:e2e:mobile": "playwright test --project=mobile-chromium",
    "test:e2e:ui": "playwright test --ui --ui-host=127.0.0.1 --ui-port=9323",
    "test:e2e:headed": "playwright test --headed --workers=1",
    "test:e2e:debug": "playwright test --debug",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@fontsource-variable/dosis": "^5.2.8",
    "@fontsource-variable/libre-franklin": "^5.2.8",
    "@fontsource-variable/mulish": "^5.2.8",
    "motion": "^12.38.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.4.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.2",
    "prettier": "^3.3.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.4.2"
  }
}
